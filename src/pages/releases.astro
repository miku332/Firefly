---
import GitHubReleases from "@components/widget/GitHubReleases.svelte";
import { Icon } from "astro-icon/components";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { githubReleasesConfig } from "@/config/githubReleasesConfig";
import "@/styles/releases.css";

const repos = githubReleasesConfig.repos.map((r) => ({
	owner: r.owner,
	repo: r.repo,
	label: r.label,
	desc: r.desc,
	cover: r.cover,
}));
---

<MainGridLayout title="GitHub Releases 下载" description="杀戮尖塔2 GitHub Releases 下载">
	<div class="flex w-full rounded-(--radius-large) overflow-hidden relative mb-4">
		<div class="card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full">
			<div class="relative mb-6">
				<div class="flex items-center gap-3 mb-2">
					<Icon is:inline name="material-symbols:download-rounded" class="text-3xl text-(--primary)" />
					<h1 class="text-2xl md:text-3xl font-bold text-black/90 dark:text-white/90">GitHub Releases 下载</h1>
				</div>
				<p class="text-sm text-neutral-500 dark:text-neutral-400">选择模组查看 Releases 并下载</p>
			</div>
			{
				repos.length === 0 ? (
					<div class="flex flex-col items-center justify-center py-16 text-neutral-400 dark:text-neutral-500">
						<Icon is:inline name="material-symbols:inbox-outline-rounded" class="text-5xl mb-4 opacity-40" />
						<p class="text-lg font-medium">暂无配置仓库</p>
					</div>
				) : (
					<GitHubReleases repos={repos} client:load />
				)
			}
		</div>
	</div>
</MainGridLayout>


